{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "IntuneWksManager.sln", "-c", "Debug"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "build (Release)",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "IntuneWksManager.sln", "-c", "Release"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "silent" }
    }
  ]
}
