# Remplacer le web.config
@"
<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" 
                  arguments=".\IntuneWksManager.dll" 
                  stdoutLogEnabled="true" 
                  stdoutLogFile=".\logs\stdout" 
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Development" />
          <environmentVariable name="ASPNETCORE_DETAILEDERRORS" value="true" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
"@ | Out-File -FilePath "C:\inetpub\wwwroot\IntuneWksManager\web.config" -Encoding UTF8

# Créer le dossier logs si nécessaire
mkdir C:\inetpub\wwwroot\IntuneWksManager\logs -Force
icacls "C:\inetpub\wwwroot\IntuneWksManager\logs" /grant "IIS_IUSRS:(OI)(CI)F"

# Redémarrer IIS
iisreset