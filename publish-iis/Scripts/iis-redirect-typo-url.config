<?xml version="1.0" encoding="utf-8"?>
<!--
  Règle de redirection pour l'URL erronée "intunewksmanagerdmin" -> "intunewksmanager/Admin"
  À ajouter dans le web.config du SITE PAR DÉFAUT (ex: C:\inetpub\wwwroot\web.config),
  dans <system.webServer>, pour que les requêtes vers /intunewksmanagerdmin redirigent vers l'app.

  Si vous n'avez pas encore <rewrite><rules>, copiez tout le bloc <rewrite> ci‑dessous.
  Sinon, ajoutez uniquement la <rule> dans votre <rules> existant.
-->
<rewrite>
  <rules>
    <rule name="Redirect typo intunewksmanagerdmin to IntuneWksManager Admin" stopProcessing="true">
      <match url="^intunewksmanagerdmin/?(.*)$" ignoreCase="true" />
      <action type="Redirect" url="/intunewksmanager/Admin{R:1}" redirectType="Permanent" />
    </rule>
  </rules>
</rewrite>
